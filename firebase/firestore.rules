rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      // Subcollections
      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Public profiles - discoverable by any signed-in user (friend search + leaderboard).
    // Each user can only write their own public profile and their own public posts.
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;

      // Public posts shared to friends' feeds. Readable by any signed-in user
      // (the app only displays posts authored by the viewer's friends).
      match /posts/{postId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == uid;
      }
    }

    // Mutual friendships. The document id is the two uids sorted and joined by "_".
    // Only the two members can read/create/delete the relationship.
    match /friendships/{pairId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 2;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.auth.uid in request.resource.data.members;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;
    }

    // Global exercises collection - read-only for all users
    match /exercises/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Public leaderboards - read-only
    match /leaderboards/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
