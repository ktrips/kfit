rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      // Subcollections
      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Public profiles - discoverable by any signed-in user (friend search + leaderboard).
    // Each user can only write their own public profile and their own public posts.
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;

      // Public posts shared to friends' feeds. Readable by any signed-in user
      // (the app only displays posts authored by the viewer's friends).
      match /posts/{postId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == uid;
      }
    }

    // Mutual friendships. The document id is the two uids sorted and joined by "_".
    // Only the two members can read/create/delete the relationship.
    match /friendships/{pairId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 2;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members
                    && request.auth.uid in request.resource.data.members;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;
    }

    // App config (Premium secret code etc.) - readable by all, writable only by admin
    match /appConfig/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "kenichiyoshida13@gmail.com";
    }

    // Global exercises collection - read-only for all users
    match /exercises/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Public leaderboards - read-only
    match /leaderboards/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // 90日再検査チャレンジ: 未ログインでも登録・PV計測可
    match /challenge_registrations/{docId} {
      // 読み取りは管理者のみ
      allow read: if request.auth != null
                  && request.auth.token.email == "kenichiyoshida13@gmail.com";
      // 誰でも新規登録可（メール重複チェックのため既存doc読み取りも許可）
      allow create: if true;
      allow list: if true;   // 重複チェック用クエリ
    }

    match /challenge_analytics/{docId} {
      // 統計は誰でも読める（登録数・PV表示）
      allow read: if true;
      // PVカウント・登録カウントの更新は誰でも可
      allow write: if true;
    }

    // 公開統計（7/30/90日継続率など）。
    // 書き込みは Cloud Functions（Admin SDK、rules 対象外）のみ。
    match /public-stats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 週間レポート共有カード（fit.ktrips.net/r/{shareId} で未ログイン閲覧可）。
    // ID は推測不能なランダム値。本人のみ発行でき、変更・削除は本人のみ。
    match /shared-reports/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.authorUid == request.auth.uid;
    }

    // ライブカウンター（LP の「今日 XX 人が挑戦中」表示用）
    // 未認証でも読み取り可。書き込みはログイン済みユーザーのみ。
    match /stats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
